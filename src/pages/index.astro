---
const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

const mainFigures = [
  {
    src: 'figures/figure-1.png',
    label: 'Figure 1',
    title: 'Baseline six-domain symptom network and structural-control profile',
    caption:
      'The baseline network contained 104 nodes across six domains. A compact driver core from diet, behavior and emotion governed static structural control while remaining distinct from high-strength symptoms.',
  },
  {
    src: 'figures/figure-2.png',
    label: 'Figure 2',
    title: 'Cross-lagged panel network across two waves',
    caption:
      'In 6,092 matched adolescents, emotional distress was the strongest net temporal source. Behavior and physical activity sat downstream, and digital use did not lead the system.',
  },
  {
    src: 'figures/figure-3.png',
    label: 'Figure 3',
    title: 'Bayesian directed graph convergence',
    caption:
      'A Bayesian directed graph learned from baseline scores converged with the longitudinal CLPN pattern, placing emotional distress on the source side of the network.',
  },
  {
    src: 'figures/figure-4.png',
    label: 'Figure 4',
    title: 'Cross-cultural triangulation in young adults',
    caption:
      'Across 147,506 young adults from 240 countries, the emotional domain was the strongest hub, while adult social-media frequency was weakly coupled to the broader health network.',
  },
  {
    src: 'figures/figure-5.png',
    label: 'Figure 5',
    title: 'Independent UK longitudinal replication',
    caption:
      'The Millennium Cohort Study confirmed the screen-sink pattern from age 14 to 17, with internalizing distress among the upstream sources.',
  },
];

const supplementFigures = Array.from({ length: 20 }, (_, index) => ({
  src: `figures/figure-s${index + 1}.png`,
  label: `Figure S${index + 1}`,
}));
---

